---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "My personal website and blog." } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-950 text-gray-100 antialiased min-h-screen flex flex-col font-sans selection:bg-teal-500/30">
		<header class="w-full border-b border-gray-800/60 bg-gray-950/80 backdrop-blur-md sticky top-0 z-50">
			<div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight hover:text-teal-400 transition-colors">
                    yruyrui
				</a>
				<nav class="flex gap-6 text-sm font-medium text-gray-400">
					<a href="/" class="hover:text-gray-100 transition-colors">Home</a>
					<a href="/blog" class="hover:text-gray-100 transition-colors">Blog</a>
				</nav>
			</div>
		</header>

		<main class="flex-1 w-full max-w-4xl mx-auto px-6 py-12 flex flex-col gap-16">
			<slot />
		</main>

		<footer class="w-full border-t border-gray-800/60 mt-12 py-8 text-center text-gray-500 text-sm">
			<div class="max-w-4xl mx-auto px-6">
				&copy; {new Date().getFullYear()} MyPage. All rights reserved.
			</div>
		</footer>
	</body>
</html>

