---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog | MyPage" description="Read my latest thoughts on software development and technology.">
	<section class="flex flex-col gap-8">
		<div>
			<h1 class="text-4xl font-extrabold tracking-tight text-gray-100">Blog</h1>
			<p class="text-lg text-gray-400 mt-2">Thoughts, learnings, and technical deep dives.</p>
		</div>

		<div class="flex flex-col gap-6">
			{sortedPosts.map(post => (
				<a href={`/blog/${post.id}`} class="group flex flex-col gap-2 p-6 rounded-2xl border border-gray-800 bg-gray-900/30 hover:bg-gray-800/50 hover:border-gray-700 transition-all">
					<div class="flex items-center gap-3 text-sm text-gray-500">
						<time datetime={post.data.pubDate.toISOString()}>
							{post.data.pubDate.toLocaleDateString('en-us', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
						</time>
						{post.data.tags && post.data.tags.length > 0 && (
							<>
								<span>&middot;</span>
								<div class="flex gap-2">
									{post.data.tags.map(tag => (
										<span class="text-teal-500/80 group-hover:text-teal-400 transition-colors">#{tag}</span>
									))}
								</div>
							</>
						)}
					</div>
					<h2 class="text-2xl font-bold text-gray-200 group-hover:text-teal-400 transition-colors">{post.data.title}</h2>
					<p class="text-gray-400 leading-relaxed mt-1">{post.data.description}</p>
				</a>
			))}
		</div>
	</section>
</Layout>