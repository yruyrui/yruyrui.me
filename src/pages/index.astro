---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<Layout title="Home | MyPage">
	<section class="flex flex-col gap-4">
		<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-100">
			Hello, I'm an <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-blue-500">yruyrui</span>.
		</h1>
		<p class="text-lg text-gray-400 leading-relaxed max-w-2xl mt-4">
			I'm a Master's student specializing in Natural Language Processing. I have a deep passion for Linux, Open Source Software (OSS), and exploring the intricacies of Input Method Editors (IMEs). Welcome to my personal slice of the internet where I share my research, coding journey, and tech explorations.
		</p>
	</section>

	<section class="flex flex-col gap-6">
		<div class="flex items-center justify-between">
			<h2 class="text-2xl font-bold tracking-tight">Recent Posts</h2>
			<a href="/blog" class="text-sm font-medium text-teal-400 hover:text-teal-300 transition-colors">View all →</a>
		</div>
		<div class="grid gap-4 sm:grid-cols-2">
			{recentPosts.length > 0 ? (
				recentPosts.map(post => (
					<a href={`/blog/${post.id}`} class="p-6 rounded-2xl border border-gray-800 bg-gray-900/50 hover:bg-gray-800/80 hover:border-gray-700 transition-all flex flex-col gap-2 group">
						<div class="text-xs font-medium text-teal-500/80 group-hover:text-teal-400 transition-colors">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-us', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
						</div>
						<h3 class="text-lg font-semibold text-gray-200 group-hover:text-white transition-colors">{post.data.title}</h3>
						<p class="text-sm text-gray-400 line-clamp-2 mt-2 group-hover:text-gray-300 transition-colors">{post.data.description}</p>
					</a>
				))
			) : (
				<p class="text-gray-500">No posts found.</p>
			)}
		</div>
	</section>

	<section class="flex flex-col gap-6">
		<h2 class="text-2xl font-bold tracking-tight">Projects & Misc</h2>
		<div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
			<a href="https://github.com/yruyrui" class="group p-5 rounded-2xl border border-gray-800 bg-gray-900/30 hover:bg-gray-800/50 hover:border-gray-700 transition-all flex flex-col items-start gap-3">
				<div class="p-2 rounded-lg bg-gray-800 text-teal-400 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
				</div>
				<div>
					<h3 class="font-medium text-gray-200 group-hover:text-teal-400 transition-colors">GitHub</h3>
					<p class="text-sm text-gray-500 mt-1">Check out my open source contributions.</p>
				</div>
			</a>
			<a href="https://www.linkedin.com/in/yruyrui/" class="group p-5 rounded-2xl border border-gray-800 bg-gray-900/30 hover:bg-gray-800/50 hover:border-gray-700 transition-all flex flex-col items-start gap-3">
				<div class="p-2 rounded-lg bg-gray-800 text-blue-400 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
				</div>
				<div>
					<h3 class="font-medium text-gray-200 group-hover:text-blue-400 transition-colors">LinkedIn</h3>
					<p class="text-sm text-gray-500 mt-1">Connect with me professionally.</p>
				</div>
			</a>
			<a href="mailto:me@yruyrui.me" class="group p-5 rounded-2xl border border-gray-800 bg-gray-900/30 hover:bg-gray-800/50 hover:border-gray-700 transition-all flex flex-col items-start gap-3">
				<div class="p-2 rounded-lg bg-gray-800 text-purple-400 group-hover:scale-110 transition-transform">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
				</div>
				<div>
					<h3 class="font-medium text-gray-200 group-hover:text-purple-400 transition-colors">Email</h3>
					<p class="text-sm text-gray-500 mt-1">Reach out for collaborations.</p>
				</div>
			</a>
		</div>
	</section>
</Layout>
